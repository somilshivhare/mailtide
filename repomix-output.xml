import { Resend } from 'resend';
import dotenv from 'dotenv';

dotenv.config();

const { RESEND_API_KEY } = process.env;

let resendClient = null;
const isMockMode = !RESEND_API_KEY || RESEND_API_KEY.includes('...') || RESEND_API_KEY === 're_';

if (!isMockMode) {
  try {
    resendClient = new Resend(RESEND_API_KEY);
  } catch (err) {
    console.warn(`Resend failed to initialize: ${err.message}. Running in mock mode.`);
  }
} else {
  console.log('RESEND_API_KEY is not set or is a placeholder. Resend service running in MOCK mode.');
}

/**
 * Sends an email using Resend API or mock fallback.
 * @param {string} to - Recipient email address
 * @param {string} subject - Email subject line
 * @param {string} html - Email HTML body content
 * @param {string} [from] - Sender email address
 * @returns {Promise<string>} The Resend email ID
 */
export const sendEmail = async (to, subject, html, from) => {
  try {
    const sender = from || process.env.SENDER_EMAIL || 'Mailtide <onboarding@resend.dev>';
    
    if (isMockMode || !resendClient) {
      console.log(`[MOCK EMAIL] From: ${sender} | To: ${to} | Subject: ${subject}`);
      // Simulate network delay
      await new Promise((resolve) => setTimeout(resolve, 100));
      return `mock_re_${Math.random().toString(36).substr(2, 9)}`;
    }

    const response = await resendClient.emails.send({
      from: sender,
      to,
      subject,
      html
    });

    if (response.error) {
      throw new Error(response.error.message || 'Unknown Resend error');
    }

    return response.data.id;
  } catch (err) {
    console.error(`Error sending email to ${to}: ${err.message}`);
    throw err;
  }
};
