# =========================================================================
# MailFlow Backend Environment Configuration
# Copy this file to '.env' if it gets renamed, and customize as needed.
# =========================================================================

# 1. Server Configuration
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# 2. Database & Cache Connection URLs
# Change these to MongoDB Atlas or Upstash Redis URLs if deploying to Render/Vercel.
MONGODB_URI=mongodb://127.0.0.1:27017/mailflow
REDIS_URL=redis://127.0.0.1:6379

# 3. Security Credentials
JWT_SECRET=super-secure-mailflow-dev-jwt-secret-key-12345
# Optional: Set this to verify incoming Resend Svix signatures
WEBHOOK_SECRET=

# 4. Third-Party Provider Credentials
# Keeping these as placeholders/empty boots the service in MOCK mode.
# Replace with actual keys to send real emails and run real AI generation.
RESEND_API_KEY=re_mock_key_for_testing
GEMINI_API_KEY=gemini_mock_key_for_testing

# 5. Email Domain Config
# In production, use your verified custom domain (e.g. hello@yourdomain.com)
SENDER_EMAIL=MailFlow <onboarding@resend.dev>
